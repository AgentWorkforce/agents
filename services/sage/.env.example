AWS_PROFILE=your-aws-profile
SST_STAGE=dev

# Required for stages that manage Cloudflare DNS or certificates.
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_DEFAULT_ACCOUNT_ID=your-cloudflare-account-id

# Sage application secrets.
OPENROUTER_API_KEY=your-openrouter-api-key
SUPERMEMORY_API_KEY=your-supermemory-api-key
NANGO_SECRET_KEY=your-nango-secret-key
# Bearer token Sage uses to call the cloud web app per-workspace integrations
# lookup endpoint. Loaded into the SageCloudApiToken SST secret by deploy.sh.
CLOUD_API_TOKEN=your-cloud-api-token

# Local single-tenant fallbacks. These are ONLY used when running Sage outside
# the deployed Worker (e.g. `./services/sage/deploy.sh local`) without
# CLOUD_API_URL/CLOUD_API_TOKEN; they are not injected into deployed stages.
NANGO_GITHUB_CONNECTION_ID=sage-github
NANGO_SLACK_CONNECTION_ID=sage-slack
SAGE_WORKSPACE_ID=dev
GITHUB_ORG=AgentWorkforce
PORT=3777

# Optional override for local Docker smoke tests.
SAGE_APP_ENV_FILE=../../../sage/.env
